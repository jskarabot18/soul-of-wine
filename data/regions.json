      "D3": { "label": "Tradition ↔ Reinvention", "pos": "Deep custodial tradition", "neg": "Radical reinvention, disruption" },
      "D4": { "label": "Individual ↔ Collective", "pos": "Strongly individual, solitary", "neg": "Strongly collective, communal" },
      "D5": { "label": "Urgency ↔ Timelessness", "pos": "Urgent, present-focused", "neg": "Timeless, eternal" },
      "D6": { "label": "Earthly ↔ Transcendent", "pos": "Deeply grounded, earthly", "neg": "Transcendent, spiritual" }
    },
    "clusters": {
      "Old World Interior": { "n": 10, "description": "Deeply interior, tradition-bound, place-defined. Winemaker as custodian. Long temporal arcs." },
      "Outward Ease": { "n": 5, "description": "Outward-facing, pleasure-oriented, accessible. Generosity over difficulty." },
      "New World Reinvention": { "n": 12, "description": "Constructed identities, urgency, disruption. Winemaker as pioneer or revolutionary." },
      "Old World Exterior": { "n": 7, "description": "Institutional, market-facing, yet tradition-holding. Commercial depth." },
      "Against the Odds": { "n": 10, "description": "Defined by struggle, extreme terrain, or cultural marginalisation. Endurance as identity." },
      "The Moderates": { "n": 15, "description": "Balanced across all dimensions. No extreme positions. Equilibrium over extremity." }
    }
